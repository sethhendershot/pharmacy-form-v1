<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= stage === 2 ? 'Employee Review' : stage === 3 ? 'Pharmacy Director Approval' : stage === 4 ? 'DTG Addition' : stage === 5 ? 'Form Completion' : 'Approval' %></title>
  <link rel="icon" href="/images/favicon.png">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="text-center mb-4 p-3">
    <img src="/images/trinity-health-banner.png" alt="Trinity Health Banner" style="max-width: 350px;">
  </div>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-10">
        <div class="card">
          <div class="card-header">
            <h1 class="h3 mb-0"><%= stage === 2 ? 'Employee Review' : stage === 3 ? 'Pharmacy Director Approval' : 'Approval' %></h1>
          </div>
          <div class="card-body">
            <h4><%= stage === 5 ? 'All Submitted Data' : 'Submitted Data' %></h4>
            <div class="row">
              <% Object.keys(entry.data).forEach(key => { %>
                <% if (key !== 'Manager Verify Accuracy' && key !== 'Manager Verified Login') { %>
                <% if (key.includes('Signature')) { %>
                  <div class="col-md-6 mb-3">
                    <label class="form-label"><strong><%= key %>:</strong></label><br>
                    <img src="<%= entry.data[key] %>" alt="Signature" style="border:1px solid #000; max-width:100%;">
                  </div>
                <% } else { %>
                  <div class="col-md-6 mb-3">
                    <strong><%= key %>:</strong> <%= entry.data[key] %>
                  </div>
                <% } %>
                <% } %>
              <% }); %>
            </div>
            
            <hr>
            
            <form action="/stage/<%= stage %>/<%= entry.id %>" method="POST">
              <% if (stage === 2) { %>
                <h4>Employee Verification</h4>
                <!--
                <div class="mb-3 form-check">
                  <input class="form-check-input" type="checkbox" name="Employee Verify Accuracy" id="EmployeeVerifyAccuracy">
                  <label class="form-check-label" for="EmployeeVerifyAccuracy">
                    I verify the accuracy of the information above
                  </label>
                </div>
                -->
                <!--
                <div class="mb-3 form-check">
                  <input class="form-check-input" type="checkbox" name="Employee Verified Login" id="EmployeeVerifiedLogin">
                  <label class="form-check-label" for="EmployeeVerifiedLogin">
                    I have verified the user HAS successfully logged in to Pyxis ES and has established Bio-ID
                  </label>
                </div>
                -->
                <div class="mb-3 form-check">
                  <input class="form-check-input" type="checkbox" name="Employee Agreement" id="EmployeeAgreement" required>
                  <label class="form-check-label" for="EmployeeAgreement">
                    By Checking this box I agree that I have read the statement
                  </label>
                </div>
                <div class="mb-3">
                  <label class="form-label">Employee Signature</label>
                  <canvas id="EmployeeSignatureCanvas" width="400" height="200" style="border:1px solid #000;"></canvas>
                  <input type="hidden" name="Employee Signature" id="EmployeeSignatureData">
                  <button type="button" class="btn btn-sm btn-secondary mt-1" onclick="clearSignature('EmployeeSignature')">Clear</button>
                </div>
              <% } else if (stage === 3) { %>
                <h4>Pharmacy Director Approval</h4>
                <div class="mb-3">
                  <label class="form-label">Pharmacy Director Signature</label>
                  <canvas id="PharmacyDirectorSignatureCanvas" width="400" height="200" style="border:1px solid #000;"></canvas>
                  <input type="hidden" name="Pharmacy Director Signature" id="PharmacyDirectorSignatureData">
                  <button type="button" class="btn btn-sm btn-secondary mt-1" onclick="clearSignature('PharmacyDirectorSignature')">Clear</button>
                </div>
                <div class="mb-3">
                  <label for="approvalDate" class="form-label">Approval Date</label>
                  <input type="date" class="form-control" id="approvalDate" name="Pharmacy Director Approval Date" required>
                </div>
              <% } else if (stage === 4) { %>
                <h4>DTG Addition</h4>
                <p>Add <%= entry.data['First Name'] %> <%= entry.data['Middle Initial'] || '' %> <%= entry.data['Last Name'] %> to the Pyxis ES Group</p>
                
                <h5>PowerShell Command:</h5>
                <pre>Add-ADGroupMember -Identity "Pyxis ES" -Members "<%= entry.data['Trinity Employee ID Number'] %>"</pre>
                
                <div class="mb-3 form-check">
                  <input class="form-check-input" type="checkbox" name="The user has been added to the Security Group" id="DTGCheckbox" required>
                  <label class="form-check-label" for="DTGCheckbox">
                    The user has been added to the Security Group
                  </label>
                </div>
              <% } else if (stage === 5) { %>
                <h4>Form Completion</h4>
                <div class="mb-3">
                  <label class="form-label">Completion Signature</label>
                  <canvas id="CompletionSignatureCanvas" width="400" height="200" style="border:1px solid #000;"></canvas>
                  <input type="hidden" name="Completion Signature" id="CompletionSignatureData">
                  <button type="button" class="btn btn-sm btn-secondary mt-1" onclick="clearSignature('CompletionSignature')">Clear</button>
                </div>
              <% } %>
              
              <button type="submit" class="btn btn-primary"><%= stage === 2 ? 'Submit Employee Review' : stage === 3 ? 'Submit Pharmacy Director Approval' : stage === 4 ? 'Add to DTG' : stage === 5 ? 'Complete Form' : 'Submit Approval' %></button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <footer class="text-center mt-5">
    <p>DTG Pyxis Access v1.0.0</p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Signature pad functionality
    function initSignaturePad(canvasId) {
      const canvas = document.getElementById(canvasId + 'Canvas');
      const ctx = canvas.getContext('2d');
      let drawing = false;

      // Set drawing properties
      ctx.strokeStyle = 'black';
      ctx.lineWidth = 2;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';

      canvas.addEventListener('mousedown', (e) => startDrawing(e));
      canvas.addEventListener('mousemove', draw);

      // Global listeners for mouseup and touchend to handle releases outside canvas
      document.addEventListener('mouseup', stopDrawing);
      canvas.addEventListener('mouseout', stopDrawing);

      canvas.addEventListener('touchstart', (e) => {
        e.preventDefault();
        startDrawing(e.touches[0]);
      });
      canvas.addEventListener('touchmove', (e) => {
        e.preventDefault();
        draw(e.touches[0]);
      });
      // Global touchend
      document.addEventListener('touchend', (e) => {
        e.preventDefault();
        stopDrawing();
      });

      function startDrawing(e) {
        drawing = true;
        const rect = canvas.getBoundingClientRect();
        ctx.beginPath();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        ctx.moveTo(x, y);
      }

      function draw(e) {
        if (!drawing) return;
        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        ctx.lineTo(x, y);
        ctx.stroke();
      }

      function stopDrawing() {
        drawing = false;
        const dataURL = canvas.toDataURL();
        document.getElementById(canvasId + 'Data').value = dataURL;
      }
    }

    <% if (stage === 2) { %>
      initSignaturePad('EmployeeSignature');
    <% } else if (stage === 3) { %>
      initSignaturePad('PharmacyDirectorSignature');
    <% } else if (stage === 5) { %>
      initSignaturePad('CompletionSignature');
    <% } %>

    function clearSignature(canvasId) {
      const canvas = document.getElementById(canvasId + 'Canvas');
      const ctx = canvas.getContext('2d');
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      document.getElementById(canvasId + 'Data').value = '';
    }
  </script>
</body>
</html>