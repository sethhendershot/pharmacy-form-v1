<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submit Entry for <%= form.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="text-center mb-4 p-3">
    <img src="/images/trinity-health-banner.png" alt="Trinity Health Banner" style="max-width: 350px;">
  </div>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h1 class="h3 mb-0">Submit Entry for <%= form.name %></h1>
          </div>
          <div class="card-body">
            <p><%= form.description %></p>
            <form action="/submit" method="POST">
              <% form.fields.forEach(field => { %>
                <% if (field.type === 'signature') { %>
                  <div class="mb-3">
                    <label class="form-label"><%= field.label %> <%= field.required ? '*' : '' %></label>
                    <canvas id="<%= field.label.replace(/\s/g, '') %>Canvas" width="400" height="200" style="border:1px solid #000;"></canvas>
                    <input type="hidden" name="<%= field.label %>" id="<%= field.label.replace(/\s/g, '') %>Data" value="<%= field.defaultValue || '' %>">
                    <button type="button" class="btn btn-sm btn-secondary mt-1" onclick="clearSignature('<%= field.label.replace(/\s/g, '') %>')">Clear</button>
                  </div>
                <% } else if (field.type === 'checkbox') { %>
                  <div class="mb-3 form-check">
                    <input class="form-check-input" type="checkbox" name="<%= field.label %>" id="<%= field.label.replace(/\s/g, '') %>" <%= field.defaultValue ? 'checked' : '' %>>
                    <label class="form-check-label" for="<%= field.label.replace(/\s/g, '') %>">
                      <%= field.label %>
                    </label>
                  </div>
                <% } else { %>
                  <div class="mb-3">
                    <label for="<%= field.label.replace(/\s/g, '') %>" class="form-label"><%= field.label %> <%= field.required ? '*' : '' %></label>
                    <% if (field.type === 'textarea') { %>
                      <textarea class="form-control" id="<%= field.label.replace(/\s/g, '') %>" name="<%= field.label %>" rows="3" <%= field.required ? 'required' : '' %>><%= field.defaultValue || '' %></textarea>
                    <% } else if (field.type === 'select') { %>
                      <select class="form-control" id="<%= field.label.replace(/\s/g, '') %>" name="<%= field.label %>" <%= field.required ? 'required' : '' %>>
                        <option value="">Select...</option>
                        <% field.options.forEach(opt => { %>
                          <option value="<%= opt %>" <%= opt === field.defaultValue ? 'selected' : '' %>><%= opt %></option>
                        <% }); %>
                      </select>
                    <% } else { %>
                      <input type="<%= field.type || 'text' %>" class="form-control" id="<%= field.label.replace(/\s/g, '') %>" name="<%= field.label %>" placeholder="<%= field.placeholder || '' %>" value="<%= field.defaultValue || '' %>" <%= field.required ? 'required' : '' %>>
                    <% } %>
                  </div>
                <% } %>
              <% }); %>
              
              <button type="submit" class="btn btn-primary">Submit Request</button>
              <a href="/" class="btn btn-secondary">Cancel</a>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Signature pad functionality
    function initSignaturePad(canvasId) {
      const canvas = document.getElementById(canvasId + 'Canvas');
      const ctx = canvas.getContext('2d');
      let drawing = false;

      // Set drawing properties
      ctx.strokeStyle = 'black';
      ctx.lineWidth = 2;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';

      canvas.addEventListener('mousedown', (e) => startDrawing(e));
      canvas.addEventListener('mousemove', draw);

      // Global listeners for mouseup and touchend to handle releases outside canvas
      document.addEventListener('mouseup', stopDrawing);
      canvas.addEventListener('mouseout', stopDrawing);

      canvas.addEventListener('touchstart', (e) => {
        e.preventDefault();
        startDrawing(e.touches[0]);
      });
      canvas.addEventListener('touchmove', (e) => {
        e.preventDefault();
        draw(e.touches[0]);
      });
      // Global touchend
      document.addEventListener('touchend', (e) => {
        e.preventDefault();
        stopDrawing();
      });

      function startDrawing(e) {
        drawing = true;
        const rect = canvas.getBoundingClientRect();
        ctx.beginPath();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        ctx.moveTo(x, y);
      }

      function draw(e) {
        if (!drawing) return;
        const rect = canvas.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        ctx.lineTo(x, y);
        ctx.stroke();
      }

      function stopDrawing() {
        drawing = false;
        const dataURL = canvas.toDataURL();
        document.getElementById(canvasId + 'Data').value = dataURL;
      }
    }

    // Initialize signature pads
    <% form.fields.forEach(field => { %>
      <% if (field.type === 'signature') { %>
        initSignaturePad('<%= field.label.replace(/\s/g, '') %>');
      <% } %>
    <% }); %>

    function clearSignature(canvasId) {
      const canvas = document.getElementById(canvasId + 'Canvas');
      const ctx = canvas.getContext('2d');
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      document.getElementById(canvasId + 'Data').value = '';
    }
  </script>
</body>
</html>