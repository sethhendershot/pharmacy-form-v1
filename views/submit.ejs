<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submit Entry for <%= form.name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h1 class="h3 mb-0">Submit Entry for <%= form.name %></h1>
          </div>
          <div class="card-body">
            <p><%= form.description %></p>
            <form action="/forms/<%= form.id %>/entries" method="POST">
              <div class="mb-3">
                <label for="data" class="form-label">Entry Data (JSON)</label>
                <textarea class="form-control" id="data" name="data" rows="5" placeholder='{"field1": "value1", "field2": "value2"}' required></textarea>
              </div>
              <button type="submit" class="btn btn-primary">Submit Entry</button>
              <a href="/" class="btn btn-secondary">Cancel</a>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>