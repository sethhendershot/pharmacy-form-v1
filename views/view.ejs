<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>View Submission</title>
  <link rel="icon" href="/images/favicon.png">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="text-center mb-4 p-3">
    <img src="/images/trinity-health-banner.png" alt="Trinity Health Banner" style="max-width: 350px;">
  </div>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-10">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0">Form Submission Details</h1>
            <a href="/admin" class="btn btn-secondary">Back to Dashboard</a>
          </div>
          <div class="card-body">
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>ID:</strong> <%= entry.id %>
              </div>
              <div class="col-md-6">
                <strong>Status:</strong>
                <span class="badge bg-<%= entry.status === 'submitted' ? 'primary' : entry.status === 'manager approved' ? 'warning' : entry.status === 'director approved' ? 'success' : 'danger' %>">
                  <%= entry.status %>
                </span>
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>Submitted At:</strong> <%= new Date(entry.submittedAt).toLocaleString() %>
              </div>
              <% if (entry.updatedAt) { %>
              <div class="col-md-6">
                <strong>Last Updated:</strong> <%= new Date(entry.updatedAt).toLocaleString() %>
              </div>
              <% } %>
            </div>

            <h4 class="mb-3">Form Data</h4>
            <div class="row">
              <div class="col-md-6">
                <div class="mb-3">
                  <label class="form-label fw-bold">User Type</label>
                  <p><%= entry.data['User Type'] || 'N/A' %></p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">First Name</label>
                  <p><%= entry.data['First Name'] || 'N/A' %></p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Middle Initial</label>
                  <p><%= entry.data['Middle Initial'] || 'N/A' %></p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Last Name</label>
                  <p><%= entry.data['Last Name'] || 'N/A' %></p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Email Address</label>
                  <p><%= entry.data['Email Address'] || 'N/A' %></p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Professional Credentials</label>
                  <p><%= entry.data['Professional Credentials'] || 'N/A' %></p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Primary Unit to be assigned</label>
                  <p><%= entry.data['Primary Unit to be assigned'] || 'N/A' %></p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Pyxis online tutorial completion date</label>
                  <p><%= entry.data['Pyxis online tutorial completion date'] || 'N/A' %></p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Pyxis Policy/Procedure review date</label>
                  <p><%= entry.data['Pyxis Policy/Procedure review date'] || 'N/A' %></p>
                </div>
              </div>
              <div class="col-md-6">
                <!--
                <div class="mb-3">
                  <label class="form-label fw-bold">Manager Verify Accuracy</label>
                  <p><%= entry.data['Manager Verify Accuracy'] ? 'Yes' : 'No' %></p>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Manager Verified Login</label>
                  <p><%= entry.data['Manager Verified Login'] ? 'Yes' : 'No' %></p>
                </div>
                -->
                <div class="mb-3">
                  <label class="form-label fw-bold">Employee Signature</label>
                  <% if (entry.data['Employee Signature']) { %>
                    <img src="<%= entry.data['Employee Signature'] %>" alt="Employee Signature" class="img-fluid border">
                  <% } else { %>
                    <p>No signature</p>
                  <% } %>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Manager Signature</label>
                  <% if (entry.data['Manager Signature']) { %>
                    <img src="<%= entry.data['Manager Signature'] %>" alt="Manager Signature" class="img-fluid border">
                  <% } else { %>
                    <p>No signature</p>
                  <% } %>
                </div>
                <div class="mb-3">
                  <label class="form-label fw-bold">Pharmacy Signature</label>
                  <% if (entry.data['Pharmacy Signature']) { %>
                    <img src="<%= entry.data['Pharmacy Signature'] %>" alt="Pharmacy Signature" class="img-fluid border">
                  <% } else { %>
                    <p>No signature</p>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>