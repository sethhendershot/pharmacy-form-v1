<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submission Successful</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="text-center mb-4 p-3">
    <img src="/images/trinity-health-banner.png" alt="Trinity Health Banner" style="max-width: 350px;">
  </div>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">
            <h1 class="h3 mb-0">Submission Successful</h1>
          </div>
          <div class="card-body">
            <p>Your request has been submitted successfully.</p>
            <p>Next step link: <a href="<%= nextLink %>"><%= nextLink %></a></p>
            <p><em>Note: In production, this link will be emailed to the next approver.</em></p>
            <a href="/" class="btn btn-primary">Submit Another Request</a>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <footer class="text-center mt-5">
    <p>DTG Pyxis Access v1.0.0</p>
  </footer>
</body>
</html>