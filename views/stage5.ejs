<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Form Completion</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="text-center mb-4 p-3">
    <img src="/images/trinity-health-banner.png" alt="Trinity Health Banner" style="max-width: 350px;">
  </div>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-10">
        <div class="card">
          <div class="card-header">
            <h1 class="h3 mb-0">Form Completion</h1>
          </div>
          <div class="card-body">
            <h4>All Submitted Data</h4>
            <div class="row">
              <% Object.keys(entry.data).forEach(key => { %>
                <div class="col-md-6 mb-3">
                  <strong><%= key %>:</strong>
                  <% if (key.includes('Signature')) { %>
                    <br><img src="<%= entry.data[key] %>" alt="Signature" style="border:1px solid #000; max-width:100%;">
                  <% } else { %>
                    <%= entry.data[key] %>
                  <% } %>
                </div>
              <% }); %>
            </div>
            
            <hr>
            
            <p>The form has been completed. Click below to finalize.</p>
            
            <form action="/stage/<%= stage %>/<%= entry.id %>" method="POST">
              <button type="submit" class="btn btn-success">Complete Form</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <footer class="text-center mt-5">
    <p>DTG Pyxis Access v1.0.0</p>
  </footer>
</body>
</html>