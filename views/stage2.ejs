<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stage 2: Employee Completion</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h1 class="h3 mb-0">Pyxis Medication Machine Access Request - Stage 2</h1>
            <p class="mb-0">Employee: Please complete the required training and sign below</p>
          </div>
          <div class="card-body">
            <h4>Employee Information (Provided by Manager)</h4>
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>Date:</strong> <%= entry.data.Date %>
              </div>
              <div class="col-md-6">
                <strong>Primary Unit:</strong> <%= entry.data['Primary Unit to be assigned'] %>
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-md-4">
                <strong>First Name:</strong> <%= entry.data['First Name'] %>
              </div>
              <div class="col-md-4">
                <strong>Middle Initial:</strong> <%= entry.data['Middle Initial'] %>
              </div>
              <div class="col-md-4">
                <strong>Last Name:</strong> <%= entry.data['Last Name'] %>
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>Trinity Employee ID:</strong> <%= entry.data['Trinity Employee ID Number'] %>
              </div>
              <div class="col-md-6">
                <strong>Professional Credentials:</strong> <%= entry.data['Professional Credentials'] %>
              </div>
            </div>
            <div class="row mb-3">
              <div class="col-md-6">
                <strong>User Type:</strong> <%= entry.data['User Type'] %>
              </div>
              <div class="col-md-6">
                <strong>Job Title/Role:</strong> <%= entry.data['Job Title/ User Role'] %>
              </div>
            </div>

            <hr>

            <form action="/stage/2/<%= entry.id %>" method="POST">
              <h4>Training Completion</h4>
              <div class="row mb-3">
                <div class="col-md-6">
                  <label for="tutorialDate" class="form-label">Pyxis Online Tutorial Completion Date</label>
                  <input type="date" class="form-control" id="tutorialDate" name="Pyxis online tutorial completion date" required>
                </div>
                <div class="col-md-6">
                  <label for="policyDate" class="form-label">Pyxis Policy/Procedure Review Date</label>
                  <input type="date" class="form-control" id="policyDate" name="Pyxis Policy/Procedure review date" required>
                </div>
              </div>

              <div class="mb-3">
                <h5>PYXIS ES USER SECURITY AGREEMENT</h5>
                <p>The undersigned individual understands the following:</p>
                <ol>
                  <li>The ID assigned in combination with the password selected is the individual's electronic signature. It will be used to track all transactions on the Pyxis MedStation and must not be shared with anyone.</li>
                  <li>By signing this form, the individual agrees to abide by the policy and procedures for Pyxis Med Station system now in place and comply with those as published at a future date, and have read a current copy of the Policy and Procedure.</li>
                  <li>The undersigned agrees to use BioID whenever possible.</li>
                  <li>At the end of every shift the undersigned individual will check for discrepancies and resolve them immediately before leaving per policy, otherwise the undersigned is legally responsible for all transactions listed under his/her name.</li>
                </ol>
              </div>

              <div class="row mb-3">
                <div class="col-md-6">
                  <label for="signature" class="form-label">Employee Signature</label>
                  <canvas id="signatureCanvas" width="400" height="200" style="border:1px solid #000;"></canvas>
                  <input type="hidden" name="Employee Signature" id="signatureData">
                  <button type="button" class="btn btn-sm btn-secondary mt-1" onclick="clearSignature()">Clear</button>
                </div>
                <div class="col-md-6">
                  <label for="signatureDate" class="form-label">Date</label>
                  <input type="date" class="form-control" id="signatureDate" name="Signature Date" required>
                </div>
              </div>

              <button type="submit" class="btn btn-primary">Submit Completion</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Signature pad functionality
    const canvas = document.getElementById('signatureCanvas');
    const ctx = canvas.getContext('2d');
    let drawing = false;

    canvas.addEventListener('mousedown', startDrawing);
    canvas.addEventListener('mousemove', draw);
    canvas.addEventListener('mouseup', stopDrawing);
    canvas.addEventListener('mouseout', stopDrawing);

    // Touch events for mobile
    canvas.addEventListener('touchstart', (e) => {
      e.preventDefault();
      startDrawing(e.touches[0]);
    });
    canvas.addEventListener('touchmove', (e) => {
      e.preventDefault();
      draw(e.touches[0]);
    });
    canvas.addEventListener('touchend', stopDrawing);

    function startDrawing(e) {
      drawing = true;
      ctx.beginPath();
      ctx.moveTo(e.clientX - canvas.offsetLeft, e.clientY - canvas.offsetTop);
    }

    function draw(e) {
      if (!drawing) return;
      ctx.lineTo(e.clientX - canvas.offsetLeft, e.clientY - canvas.offsetTop);
      ctx.stroke();
    }

    function stopDrawing() {
      drawing = false;
      // Save to hidden input
      const dataURL = canvas.toDataURL();
      document.getElementById('signatureData').value = dataURL;
    }

    function clearSignature() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      document.getElementById('signatureData').value = '';
    }
  </script>
</body>
</html>