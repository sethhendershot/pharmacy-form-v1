<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Pyxis ES User Access Request</title>
  <link rel="icon" href="/images/favicon.png">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="text-center mb-4 p-3">
    <img src="/images/trinity-health-banner.png" alt="Trinity Health Banner" style="max-width: 350px;">
  </div>
  <nav class="navbar navbar-light bg-light mb-4">
    <div class="container">
      <span class="navbar-brand mb-0 h1">Pyxis ES User Access Request</span>
      <a href="/login" class="btn btn-outline-primary">Admin Login</a>
    </div>
  </nav>
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h1 class="h3 mb-0">Pyxis ES User Access Request</h1>
          </div>
          <div class="card-body">
            <form action="/submit" method="POST">
              <div class="mb-3">
                <label for="UserType" class="form-label">User Type *</label>
                <select class="form-control" id="UserType" name="User Type" required>
                  <option value="">Select...</option>
                  <option value="Trinity Employee">Trinity Employee</option>
                  <option value="Contract Staff or Locum Anesthesia Provider">Contract Staff or Locum Anesthesia Provider</option>
                </select>
              </div>
              <div class="mb-3">
                <label for="FirstName" class="form-label">First Name *</label>
                <input type="text" class="form-control" id="FirstName" name="First Name" required>
              </div>
              <div class="mb-3">
                <label for="MiddleInitial" class="form-label">Middle Initial</label>
                <input type="text" class="form-control" id="MiddleInitial" name="Middle Initial">
              </div>
              <div class="mb-3">
                <label for="LastName" class="form-label">Last Name *</label>
                <input type="text" class="form-control" id="LastName" name="Last Name" required>
              </div>
              <div class="mb-3">
                <label for="ProfessionalCredentials" class="form-label">Professional Credentials *</label>
                <input type="text" class="form-control" id="ProfessionalCredentials" name="Professional Credentials" required>
              </div>
              <div class="mb-3">
                <label for="PrimaryUnittobeassigned" class="form-label">Primary Unit to be assigned *</label>
                <input type="text" class="form-control" id="PrimaryUnittobeassigned" name="Primary Unit to be assigned" required>
              </div>
              <div class="mb-3">
                <label for="Pyxisonlinetutorialcompletiondate" class="form-label">Pyxis online tutorial completion date</label>
                <input type="date" class="form-control" id="Pyxisonlinetutorialcompletiondate" name="Pyxis online tutorial completion date">
              </div>
              <div class="mb-3">
                <label for="PyxisPolicyProcedurereviewdate" class="form-label">Pyxis Policy/Procedure review date</label>
                <input type="date" class="form-control" id="PyxisPolicyProcedurereviewdate" name="Pyxis Policy/Procedure review date">
              </div>
              
              <div class="mb-3">
                <h5>PYXIS ES USER SECURITY AGREEMENT</h5>
                <p>The undersigned individual understands the following:</p>
                <ol>
                  <li>The ID assigned in combination with the password selected is the individual's electronic signature. It will be used to track all transactions on the Pyxis MedStation and must not be shared with anyone.</li>
                  <li>By signing this form, the individual agrees to abide by the policy and procedures for Pyxis Med Station system now in place and comply with those as published at a future date, and have read a current copy of the Policy and Procedure.</li>
                  <li>The undersigned agrees to use BioID whenever possible.</li>
                  <li>At the end of every shift the undersigned individual will check for discrepancies and resolve them immediately before leaving per policy, otherwise the undersigned is legally responsible for all transactions listed under his/her name.</li>
                </ol>
              </div>
              
              <div class="mb-3">
                <label class="form-label">Employee Signature *</label>
                <canvas id="EmployeeSignatureCanvas" width="400" height="200" style="border:1px solid #000;"></canvas>
                <input type="hidden" name="Employee Signature" id="EmployeeSignatureData">
                <button type="button" class="btn btn-sm btn-secondary mt-1" onclick="clearSignature('EmployeeSignature')">Clear</button>
              </div>
              
              <button type="submit" class="btn btn-primary">Submit Request</button>
              <button type="reset" class="btn btn-secondary">Reset Form</button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <footer class="text-center mt-5">
    <p>DTG Pyxis Access v1.0.0</p>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Signature pad functionality
    function initSignaturePad(canvasId) {
      const canvas = document.getElementById(canvasId + 'Canvas');
      const ctx = canvas.getContext('2d');
      let drawing = false;

      canvas.addEventListener('mousedown', startDrawing);
      canvas.addEventListener('mousemove', draw);
      canvas.addEventListener('mouseup', stopDrawing);
      canvas.addEventListener('mouseout', stopDrawing);

      canvas.addEventListener('touchstart', (e) => {
        e.preventDefault();
        startDrawing(e.touches[0]);
      });
      canvas.addEventListener('touchmove', (e) => {
        e.preventDefault();
        draw(e.touches[0]);
      });
      canvas.addEventListener('touchend', stopDrawing);

      function startDrawing(e) {
        drawing = true;
        ctx.beginPath();
        ctx.moveTo(e.clientX - canvas.offsetLeft, e.clientY - canvas.offsetTop);
      }

      function draw(e) {
        if (!drawing) return;
        ctx.lineTo(e.clientX - canvas.offsetLeft, e.clientY - canvas.offsetTop);
        ctx.stroke();
      }

      function stopDrawing() {
        drawing = false;
        const dataURL = canvas.toDataURL();
        document.getElementById(canvasId + 'Data').value = dataURL;
      }
    }

    initSignaturePad('EmployeeSignature');

    function clearSignature(canvasId) {
      const canvas = document.getElementById(canvasId + 'Canvas');
      const ctx = canvas.getContext('2d');
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      document.getElementById(canvasId + 'Data').value = '';
    }
  </script>
</body>
</html>