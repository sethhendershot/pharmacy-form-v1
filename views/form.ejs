<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= editing ? 'Edit Form' : 'Create Form' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h1 class="h3 mb-0"><%= editing ? 'Edit Form' : 'Create New Form' %></h1>
          </div>
          <div class="card-body">
            <form action="/forms<%= editing ? '/' + form.id : '' %>" method="POST">
              <div class="mb-3">
                <label for="name" class="form-label">Form Name</label>
                <input type="text" class="form-control" id="name" name="name" value="<%= editing ? form.name : '' %>" required>
              </div>
              <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea class="form-control" id="description" name="description" rows="3"><%= editing ? form.description : '' %></textarea>
              </div>
              <button type="submit" class="btn btn-primary"><%= editing ? 'Update Form' : 'Create Form' %></button>
              <a href="/" class="btn btn-secondary">Cancel</a>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>