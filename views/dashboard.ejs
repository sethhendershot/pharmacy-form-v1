<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container mt-5">
    <div class="row justify-content-center">
      <div class="col-md-10">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h1 class="h3 mb-0">Dashboard</h1>
            <div>
              <a href="/settings" class="btn btn-outline-primary me-2">Settings</a>
              <a href="/logout" class="btn btn-danger">Logout</a>
            </div>
          </div>
          <div class="card-body">
            <p class="mb-3">Hello, <%= username %>!</p>
            <p class="mb-3">Role: Admin</p>
            
            <h2 class="h4 mb-3">Pyxis Access Requests <a href="/submit" class="btn btn-success btn-sm ms-2">Submit New Request</a></h2>
            <table id="entriesTable" class="table table-striped">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Employee Name</th>
                  <th>Primary Unit</th>
                  <th>Status</th>
                  <th>Submitted At</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
  <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
  <script>
    $(document).ready(function() {
      $('#entriesTable').DataTable({
        ajax: {
          url: '/api/entries',
          dataSrc: ''
        },
        columns: [
          { data: 'id' },
          {
            data: null,
            render: function(data, type, row) {
              return (row.data['First Name'] || '') + ' ' + (row.data['Last Name'] || '');
            }
          },
          { data: 'data.Primary Unit to be assigned' },
          { data: 'status' },
          {
            data: 'submittedAt',
            render: function(data, type, row) {
              return new Date(data).toLocaleString();
            }
          },
          {
            data: null,
            render: function(data, type, row) {
              let actions = '<a href="/view/' + row.id + '" class="btn btn-sm btn-info">View</a>';
              if (row.status === 'submitted') {
                actions += ' <button class="btn btn-sm btn-warning approve-btn" data-id="' + row.id + '" data-status="manager approved">Manager Approve</button>';
              } else if (row.status === 'manager approved') {
                actions += ' <button class="btn btn-sm btn-success approve-btn" data-id="' + row.id + '" data-status="director approved">Director Approve</button>';
              } else if (row.status === 'director approved') {
                actions += ' <button class="btn btn-sm btn-secondary approve-btn" data-id="' + row.id + '" data-status="archived">Archive</button>';
              }
              actions += ' <button class="btn btn-sm btn-danger delete-btn" data-id="' + row.id + '">Delete</button>';
              return actions;
            }
          }
        ]
      });

      // Handle approve buttons
      $(document).on('click', '.approve-btn', function() {
        const id = $(this).data('id');
        const status = $(this).data('status');
        $.post('/entries/' + id + '/status', { status: status }, function(response) {
          if (response.success) {
            $('#entriesTable').DataTable().ajax.reload();
          } else {
            alert('Error updating status');
          }
        });
      });

      // Handle delete buttons
      $(document).on('click', '.delete-btn', function() {
        const id = $(this).data('id');
        if (confirm('Are you sure you want to delete this entry? This action cannot be undone.')) {
          $.ajax({
            url: '/entries/' + id,
            type: 'DELETE',
            success: function(response) {
              if (response.success) {
                $('#entriesTable').DataTable().ajax.reload();
              } else {
                alert('Error deleting entry');
              }
            },
            error: function() {
              alert('Error deleting entry');
            }
          });
        }
      });

    });
  </script>
  
  <footer class="text-center mt-5">
    <p>DTG Pyxis Access v1.0.0</p>
  </footer>
</body>
</html>